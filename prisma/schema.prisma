generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  avatar    String   @default("")
 company   String   @default("")
 role      String   @default("user")
  createdAt String   @default("")
  updatedAt String   @default("")
  invoices  Invoice[]
  sessions  Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt String
  createdAt String   @default("")
  user      User     @relation(fields: [userId], references: [id])
}

model Invoice {
  id          String   @id
  fileName    String
  merchant    String
  amount      Float
  date        String?
  tax         Float    @default(0)
  gstAmount   Float    @default(0)
  gstRate     Float    @default(0)
  category    String   @default("Other")
  subCategory String   @default("")
  items       String   @default("[]")
  currency    String   @default("USD")
  status      String   @default("processing")
  fraudScore  Float    @default(0)
  isDuplicate Boolean  @default(false)
  confidence  Float    @default(0)
  ocrText     String   @default("")
  createdAt   String
  updatedAt   String
  user        User?   @relation(fields: [userId], references: [id])
  userId      String?
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  createdAt String   @default("")
}

model Budget {
  id             String  @id @default(cuid())
  category       String
  allocated      Float
  spent          Float   @default(0)
  period         String  @default("monthly")
  alertThreshold Float   @default(80)
  createdAt      String  @default("")
  updatedAt      String  @default("")
}

model FraudAlert {
  id          String  @id @default(cuid())
  invoiceId   String
  type        String
  description String
  severity    String  @default("medium")
  createdAt   String  @default("")
  resolved    Boolean @default(false)
}
